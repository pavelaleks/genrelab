# DeepSeek (по умолчанию)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Защита входа (опционально): если задан APP_PASSWORD, приложение запросит логин и пароль
# APP_LOGIN=student
# APP_PASSWORD=придумайте_надёжный_пароль

# Опционально: переопределение провайдера/модели/endpoint
# AI_PROVIDER=deepseek
# AI_MODEL=deepseek-chat
# AI_API_BASE_URL=https://api.deepseek.com/v1/chat/completions

# Для Grok (если хотите использовать xAI вместо DeepSeek):
# GROK_API_KEY=your_grok_api_key_here
# AI_PROVIDER=grok
# AI_MODEL=grok-4-fast-reasoning
# AI_API_BASE_URL=https://api.x.ai/v1/chat/completions
